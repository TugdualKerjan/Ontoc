{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the computation method"
      },
      "name": {
        "type": "string",
        "description": "Human-readable name of the computation method"
      },
      "realizes": {
        "type": "string",
        "description": "Mathematical function or operation being computed"
      },
      "description": {
        "type": "string",
        "description": "Detailed explanation of how the computation works"
      },
      "substrate": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "mechanical",
            "fluidics",
            "biological",
            "thermodynamic",
            "electronic",
            "quantum",
            "optical"
          ]
        },
        "description": "Physical substrate(s) used for computation"
      },
      "computation_model": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "finite-state-machine",
            "pushdown-automaton",
            "register-machine",
            "random-access-machine",
            "turing-machine",
            "decision-tree",
            "external-memory-model",
            "abstract-rewriting-system",
            "combinatory-logic",
            "general-recursive-function",
            "lambda-calculus",
            "actor-model",
            "cellular-automaton",
            "interaction-nets",
            "kahn-process-networks",
            "logic-gates",
            "digital-circuits",
            "petri-nets",
            "process-calculus",
            "synchronous-data-flow"
          ]
        },
        "description": "Computational model(s) based on Wikipedia taxonomy"
      },
      "determinism": {
        "type": "string",
        "enum": ["deterministic", "stochastic"],
        "description": "Whether the computation is deterministic or stochastic"
      },
      "reversibility": {
        "type": "string",
        "enum": ["reversible", "irreversible"],
        "description": "Whether the computation is reversible"
      },
      "operations": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "MINIMIZE",
            "ADD",
            "MULTIPLY",
            "DIVIDE",
            "AND",
            "OR",
            "NOT",
            "SHIFT",
            "SAMPLE",
            "LOG",
            "ROOT",
            "FANOUT",
            "INTEGRATE",
            "MULTIPLY-by-constant",
            "HADAMARD",
            "CNOT",
            "PHASE",
            "PAULI-X",
            "PAULI-Y",
            "PAULI-Z",
            "INTEGRATE-AND-FIRE",
            "WEIGHTED-SUM",
            "THRESHOLD",
            "SEARCH",
            "SELECT",
            "NONLINEAR-TRANSFORM",
            "MEMORY",
            "DIFFERENTIATE"
          ]
        },
        "description": "Operations that can be performed"
      },
      "exactness": {
        "type": "string",
        "enum": ["exact", "approximate", "exact-in-limit", "heuristic"],
        "description": "Precision level of the computation"
      },
      "realization_type": {
        "type": "string",
        "enum": ["variational", "procedural", "statistical", "analogical"],
        "description": "Type of computational realization"
      },
      "speed_category": {
        "type": "string",
        "enum": ["instantaneous", "seconds", "minutes", "hours", "days"],
        "description": "Speed category of the computation"
      },
      "speed_notes": {
        "type": "string",
        "description": "Additional details about computation speed"
      },
      "scale_category": {
        "type": "string",
        "enum": ["single-op", "small", "medium", "large", "unbounded"],
        "description": "Scale category of computational capacity"
      },
      "compute_capacity_notes": {
        "type": "string",
        "description": "Details about computational capacity and limitations"
      },
      "energy_per_operation": {
        "type": "string",
        "description": "Energy consumption per operation"
},
      "diy": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "url": {"type": "string"},
            "label": {"type": "string"},
            "description": {"type": "string"}
          },
          "required": ["url", "label"],
          "additionalProperties": false
        },
        "description": "DIY construction resources"
      },
      "examples": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {"type": "string", "description": "Unique identifier for the example"},
            "url": {"type": "string"},
            "label": {"type": "string"},
            "description": {"type": "string"}
          },
          "required": ["id", "url", "label"],
          "additionalProperties": false
        },
        "description": "Video and demonstration examples"
      }
    },
    "required": [
      "id",
      "name",
      "realizes",
      "description",
      "substrate",
      "computation_model",
      "determinism",
      "reversibility",
      "operations",
      "exactness",
      "realization_type",
      "speed_category",
      "scale_category",
      "energy_per_operation"
    ],
    "additionalProperties": false
      }
    }
  },
  "required": ["data"],
  "additionalProperties": false
}